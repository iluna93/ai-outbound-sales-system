      "parameters": {
        "jsCode": "const normalize = (str) =>\n  str.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").toLowerCase().trim();\n\nconst originalText = $json.text || '';\nconst text = normalize(originalText);\n\n// Patron 1: buscame/quiero/necesito/hay/encuentra [nicho] en [ciudad]\nconst regex1 = /\\b(?:busc(?:a|ame|qu?ame)|quiero|necesito|hay|encuentra|dame)\\s+(.+?)\\s+en\\s+(.+)$/i;\n// Patron 2: directo \"[nicho] en [ciudad]\" — captura todo lo que va despues de 'en'\nconst regex2 = /^(.+?)\\s+en\\s+(.+)$/i;\n\nconst match1 = text.match(regex1);\nconst match2 = text.match(regex2);\n\nif (match1 && match1[1] && match1[2]) {\n  return [{ json: { niche: match1[1].trim(), city: match1[2].trim(), original: originalText } }];\n} else if (match2 && match2[1] && match2[2]) {\n  return [{ json: { niche: match2[1].trim(), city: match2[2].trim(), original: originalText } }];\n} else {\n  return [{ json: { error: 'No se pudo extraer el nicho y la ciudad.', original: originalText } }];\n}"
      },
